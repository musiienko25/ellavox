# Supabase (required for ingest and query)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase service role (if RPC needs elevated access)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: OpenAI for better natural-language → SQL (otherwise built-in patterns are used)
# OPENAI_API_KEY=sk-...
